# Copy to .env and fill in. The .env file is git-ignored.

# ---------------------------------------------------------------------------
# Provider selection. One of: anthropic | ollama | mock  (leave unset to infer).
# FORCE_MOCK_LLM=1 overrides everything and uses the deterministic mock agent.
# ---------------------------------------------------------------------------
# LLM_PROVIDER=anthropic

# --- Option A: Anthropic (hosted) ------------------------------------------
# Required for the live agent + judge. Without it, the system runs in mock mode.
ANTHROPIC_API_KEY=sk-ant-...
AGENT_MODEL=claude-haiku-4-5-20251001
# Judge model — uses same Haiku for speed + cost efficiency.
JUDGE_MODEL=claude-haiku-4-5-20251001

# --- Option B: Local LLM via Ollama (free, no API key) ---------------------
# Install Ollama (https://ollama.com), then:  ollama pull qwen2.5:7b-instruct
# Set LLM_PROVIDER=ollama above to activate.
# OLLAMA_MODEL=qwen2.5:7b-instruct
# OLLAMA_BASE_URL=http://localhost:11434      # or an ngrok URL for a remote box
# OLLAMA_JUDGE_MODEL=qwen2.5:7b-instruct
