# Copy to .env and fill in. The .env file is git-ignored.

# Anthropic API key — required for the live agent + LLM-as-judge.
# Without it, the app and eval suite run in clearly-labeled "mock mode".
ANTHROPIC_API_KEY=sk-ant-...

# Model used by the retention agent (tool-calling).
AGENT_MODEL=claude-sonnet-4-6

# Model used by the LLM-as-judge. Deliberately DIFFERENT from the agent model
# so the evaluator is independent of the system under test.
JUDGE_MODEL=claude-opus-4-8
