# Copy to .streamlit/secrets.toml (git-ignored) for local runs, OR paste these
# into the "Secrets" box of your Streamlit Community Cloud app settings.
#
# A FUNDED Anthropic key is required for the live LLM agent + judge. Without it the
# app falls back to the deterministic mock agent (clearly labeled in the UI).

ANTHROPIC_API_KEY = "sk-ant-..."
AGENT_MODEL = "claude-sonnet-4-6"
JUDGE_MODEL = "claude-opus-4-8"

# Set to "1" to force the mock agent even when a key is present (useful for a
# zero-cost public demo).
# FORCE_MOCK_LLM = "1"
